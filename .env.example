# Gmail for sending form notification emails
# STEP 1: Enable 2-Factor Auth on your Gmail
# STEP 2: Go to Google Account → Security → App Passwords
# STEP 3: Create an App Password → copy the 16-char code
GMAIL_USER=info@easytoeurope.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx
